# ── AI Content Generation ──────────────────────────────────────────────────────
# Choose one provider (or configure multiple, user selects in UI)

# Groq (free tier — fastest) → https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# HuggingFace (free) → https://huggingface.co/settings/tokens
HF_API_KEY=hf_xxxxxxxxxxxxxxxxxxxx

# Google Gemini (free tier) → https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxx

# Ollama (local, 100% free) — just set base URL if different
OLLAMA_BASE_URL=http://localhost:11434


# ── YouTube ────────────────────────────────────────────────────────────────────
# Create at https://console.cloud.google.com → APIs → YouTube Data API v3
YT_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
YT_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxx
# Get refresh token by visiting http://localhost:3000/auth/youtube after starting server
YT_REFRESH_TOKEN=


# ── Facebook / Instagram ───────────────────────────────────────────────────────
# Get a Page Access Token from https://developers.facebook.com/tools/explorer
FB_PAGE_ACCESS_TOKEN=
FB_PAGE_ID=


# ── TikTok ─────────────────────────────────────────────────────────────────────
# Register app at https://developers.tiktok.com → Content Posting API
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
# Get access token via OAuth flow at http://localhost:3000/auth/tiktok
TIKTOK_ACCESS_TOKEN=
TIKTOK_OPEN_ID=


# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3001
